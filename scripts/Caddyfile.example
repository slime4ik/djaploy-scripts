# djaploy — конфиг Caddy: автоматический HTTPS (Let's Encrypt) + reverse proxy.
# Caddy сам выпускает и продлевает SSL-сертификат для твоего домена — руками ничего не нужно.
# Это упрощённый пример того, что мы генерируем; реальный собирается под твой проект.

your-domain.com {
    # Деплой без простоя: на время пересборки контейнера запросы придерживаются
    # и ретраятся, а не падают в 502. Пользователи не замечают обновления.
    reverse_proxy your-service:8000 {
        lb_try_duration 30s
        lb_try_interval 250ms
    }

    # WebSocket (ws/wss) проксируется reverse_proxy автоматически — отдельной настройки не нужно.
}

# (опционально) Grafana под /grafana, если включён мониторинг и закрыт VPN:
# your-domain.com {
#     handle_path /grafana/* {
#         reverse_proxy grafana:3000
#     }
# }
